{
  "Rules": [
    {
      "ID": "cleanup-unconfirmed-uploads",
      "Filter": {
        "Prefix": "uploads/unconfirmed/"
      },
      "Status": "Enabled",
      "Expiration": {
        "Days": 1
      }
    },
    {
      "ID": "cleanup-incomplete-multipart",
      "Filter": {
        "Prefix": ""
      },
      "Status": "Enabled",
      "AbortIncompleteMultipartUpload": {
        "DaysAfterInitiation": 1
      }
    }
  ]
}
